{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "django: runserver",
      "type": "shell",
      "command": "python",
      "args": ["manage.py", "runserver", "0.0.0.0:8000"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "tailwind: watch",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "dev: all",
      "dependsOn": ["django: runserver", "tailwind: watch"],
      "dependsOrder": "parallel",
      "group": "build",
      "problemMatcher": []
    }
  ]
}